// Marlo Luxury Rentals — Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth compatible) ────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  passwordHash    String?
  image           String?
  role             UserRole  @default(CUSTOMER)
  stripeCustomerId String?   @unique
  kycStatus        KycStatus @default(UNVERIFIED)
  kycSubmittedAt   DateTime?
  kycFullName      String?
  kycDateOfBirth   DateTime?
  kycDocumentType  String?
  kycDocumentNumber String?
  stripeVerificationSessionId String? @unique
  availabilityEmailOptOut Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  verificationTokens VerificationToken[]
  rentals         Rental[]
  subscriptions   Subscription[]
  orders          Order[]
  favorites       Favorite[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  token      String   @unique
  identifier String
  userId     String?
  expires    DateTime
  type       TokenType @default(EMAIL_VERIFICATION)

  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([identifier, token])
  @@index([token])
}

// ─── Catalog ────────────────────────────────────────────────────────────────

model Item {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  description     String      @db.Text
  category        ItemCategory
  brand           String
  model           String?
  referenceNumber String?
  retailPrice     Int         // in cents
  dailyRate       Int         // in cents
  weeklyRate      Int?        // in cents
  monthlyRate     Int?        // in cents
  depositAmount   Int         // in cents, refundable
  images          String[]
  available       Boolean     @default(true)
  featured        Boolean     @default(false)
  purchasable     Boolean     @default(false)
  purchasePrice   Int?        // in cents; null = not for sale
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  rentals         Rental[]
  orderItems      OrderItem[]
  purchaseConversions PurchaseConversion[]
  favorites       Favorite[]

  @@index([category])
  @@index([available])
  @@index([slug])
}

// ─── Rentals ────────────────────────────────────────────────────────────────

model Rental {
  id              String       @id @default(cuid())
  userId          String
  itemId          String
  status          RentalStatus @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  totalAmount     Int          // in cents (rental cost only, excluding deposit)
  depositAmount   Int          // in cents (tiered: 150/300/500 EUR)
  depositRefunded Boolean      @default(false)
  depositIntentId String?      // Stripe PaymentIntent ID for deposit hold
  depositCaptured Boolean      @default(false)
  depositCaptureAmount Int?    // in cents, for partial capture on damage
  waiverPurchased Boolean      @default(false)
  waiverAmount    Int?         // in cents (e.g. 1900 = €19)
  shippingAddress Json?
  stripePaymentId String?
  notes           String?      @db.Text
  purchaseLeadSentAt   DateTime?   // set when purchase offer email is sent
  convertedToPurchaseAt DateTime?  // set when purchase is completed
  purchaseCreditAmount  Int?        // in cents, rental fee applied as credit
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id])
  item            Item         @relation(fields: [itemId], references: [id])
  conditionLogs   ConditionLog[]
  purchaseConversion PurchaseConversion?

  @@index([userId])
  @@index([itemId])
  @@index([status])
  @@index([startDate, endDate])
}

// ─── Condition Logs ─────────────────────────────────────────────────────────

model ConditionLog {
  id        String          @id @default(cuid())
  rentalId  String
  phase     ConditionPhase
  photos    String[]        // base64 data URLs (JPEG, resized client-side)
  status    ConditionStatus
  notes     String?         @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  rental    Rental          @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@unique([rentalId, phase])
  @@index([rentalId])
}

// ─── Subscriptions ──────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 SubscriptionPlan
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user                 User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([stripeSubscriptionId])
}

// ─── Orders ─────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Int         // in cents
  stripePaymentId String?
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  itemId    String
  quantity  Int      @default(1)
  unitPrice Int      // in cents
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id])

  @@index([orderId])
  @@index([itemId])
}

// ─── Purchase Conversions ────────────────────────────────────────────────────

model PurchaseConversion {
  id              String   @id @default(cuid())
  rentalId        String   @unique
  itemId          String
  userId          String
  purchasePrice   Int      // in cents (retail price at time of conversion)
  creditApplied   Int      // in cents (last rental fee credited)
  finalAmount     Int      // in cents (purchasePrice - creditApplied)
  stripePaymentId String?
  status          PurchaseConversionStatus @default(PENDING)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rental          Rental   @relation(fields: [rentalId], references: [id])
  item            Item     @relation(fields: [itemId], references: [id])

  @@index([userId])
  @@index([itemId])
  @@index([status])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ItemCategory {
  WATCH
  JEWELRY
  BAG
  ACCESSORY
  OTHER
}

enum RentalStatus {
  PENDING
  CONFIRMED
  ACTIVE
  RETURNED
  CANCELLED
  OVERDUE
}

enum SubscriptionPlan {
  BASIC      // random item per month
  PREMIUM    // choose from curated selection
  VIP        // white-glove, concierge selection
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum PurchaseConversionStatus {
  PENDING
  PAID
  CANCELLED
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ConditionPhase {
  DISPATCH
  RETURN
}

enum ConditionStatus {
  PRISTINE
  MINOR_WEAR
  DAMAGE
  MISSING_ITEM
}

// ─── Marketing ──────────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ─── Favorites / Wishlist ─────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}
