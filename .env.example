# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/marlo_db?schema=public"

# NextAuth.js
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="noreply@marloluxury.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (test mode — never use live keys without CEO approval)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook secret — from `stripe listen --forward-to localhost:3000/api/payments/webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe subscription price IDs — create products in Stripe Dashboard (test mode)
# Product: "Marlo Basic" → Price: $99/month recurring
STRIPE_PRICE_BASIC="price_..."
# Product: "Marlo Premium" → Price: $199/month recurring
STRIPE_PRICE_PREMIUM="price_..."
# Product: "Marlo VIP" → Price: $499/month recurring
STRIPE_PRICE_VIP="price_..."

# ─── DHL Express (MAR-34) ───────────────────────────────────────────────────
# Get credentials from DHL Business Customer Portal:
# https://developer.dhl.com/user/apps — create an app and get API key + secret.
# Account number is your 10-digit DHL Express account number.
DHL_API_KEY="your-dhl-api-key"
DHL_API_SECRET="your-dhl-api-secret"
DHL_ACCOUNT_NUMBER="123456789"
# Set to "true" for sandbox/test mode (no real shipments created)
DHL_SANDBOX="true"

# Marlo shipper identity (Absender / Stammdaten)
DHL_SHIPPER_NAME="Marlo Luxury Rentals"
DHL_SHIPPER_COMPANY="Marlo Luxury Rentals GmbH"
DHL_SHIPPER_ADDRESS1="Musterstraße 1"
DHL_SHIPPER_CITY="Köln"
DHL_SHIPPER_POSTAL_CODE="50667"
DHL_SHIPPER_COUNTRY_CODE="DE"
DHL_SHIPPER_PHONE="+49221000000"
DHL_SHIPPER_EMAIL="versand@marloluxury.com"
