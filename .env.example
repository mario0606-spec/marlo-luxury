# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/marlo_db?schema=public"

# NextAuth.js
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="noreply@marloluxury.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (test mode — never use live keys without CEO approval)
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook secret — from `stripe listen --forward-to localhost:3000/api/payments/webhook`
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe subscription price IDs — create products in Stripe Dashboard (test mode)
# Product: "Marlo Basic" → Price: $99/month recurring
STRIPE_PRICE_BASIC="price_..."
# Product: "Marlo Premium" → Price: $199/month recurring
STRIPE_PRICE_PREMIUM="price_..."
# Product: "Marlo VIP" → Price: $499/month recurring
STRIPE_PRICE_VIP="price_..."

# ─── DHL Paket Germany (MAR-34) ─────────────────────────────────────────────
# DHL Paket is the correct product for DACH domestic shipments.
# Registration: https://www.dhl.de/de/geschaeftskunden/paket/versandsoftware/dhl-geschaeftskunden-api.html
#
# Step 1: Register at developer.dhl.com → create app → add "DHL Parcel Germany" product → get API key
# Step 2: Log into Geschäftskundenportal (GKP) at geschaeftskunden.dhl.de → get username + password
# Step 3: In GKP under "Vertragsprodukte" find your 14-character billing number for DHL Paket + Retoure
#
# Set DHL_SANDBOX=true to use DHL test credentials (free, no real shipments)
DHL_SANDBOX="true"

# developer.dhl.com API key (from your app with "DHL Parcel Germany" product)
DHL_API_KEY="your-dhl-api-key"

# DHL Geschäftskundenportal login (https://geschaeftskunden.dhl.de)
DHL_GKP_USER="your-gkp-username"
DHL_GKP_PASS="your-gkp-password"

# 14-character billing number from GKP → Vertragsprodukte
# Format: [10-digit EKP][2-digit product][2-digit participation] e.g. "33333333330101"
DHL_BILLING_NUMBER="33333333330101"
DHL_RETOURE_BILLING_NUMBER="33333333330701"  # separate Retoure line item in GKP

# Marlo shipper identity — Absender printed on every label
DHL_SHIPPER_NAME="Mario Simic"
DHL_SHIPPER_COMPANY="Marlo Luxury Rentals GmbH"
DHL_SHIPPER_STREET="Musterstraße"
DHL_SHIPPER_HOUSE_NUMBER="1"
DHL_SHIPPER_CITY="Köln"
DHL_SHIPPER_POSTAL_CODE="50667"
DHL_SHIPPER_COUNTRY_CODE="DEU"
DHL_SHIPPER_PHONE="+49221000000"
DHL_SHIPPER_EMAIL="versand@marloluxury.com"
